{
  "version": 2,
  "functions": {
    "api/*.js": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    { "src": "/api/(.*)",      "dest": "/api/$1" },
    { "src": "/cursos",        "dest": "/public/cursos.html" },
    { "src": "/curso01",       "dest": "/public/curso01.html" },
    { "src": "/curso02",       "dest": "/public/curso02.html" },
    { "src": "/curso03",       "dest": "/public/curso03.html" },
    { "src": "/login",         "dest": "/public/login.html" },
    { "src": "/admin",         "dest": "/public/admin.html" },
    { "src": "/guia/gracias",  "dest": "/public/guia-gracias.html" },
    { "src": "/guia",          "dest": "/public/guia.html" },
    { "src": "/(.*)",          "dest": "/public/$1" }
  ]
}
