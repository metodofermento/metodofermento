{
  "version": 2,
  "outputDirectory": "public",
  "functions": {
    "api/*.js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/cursos",     "destination": "/cursos.html" },
    { "source": "/curso01",    "destination": "/curso01.html" },
    { "source": "/curso02",    "destination": "/curso02.html" },
    { "source": "/curso03",    "destination": "/curso03.html" },
    { "source": "/login",      "destination": "/login.html" },
    { "source": "/admin",      "destination": "/admin.html" },
    { "source": "/guia",       "destination": "/guia.html" },
    { "source": "/guia/gracias", "destination": "/guia-gracias.html" },
    { "source": "/",           "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
